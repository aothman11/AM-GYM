{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "amgym_v3.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/mwvideo", "dest": "/api/mwvideo.js" },
    { "src": "/api/exercise", "dest": "/api/exercise.js" },
    { "src": "/(.*)", "dest": "/amgym_v3.html" }
  ]
}
